https://dpodoesnt.work, http://dpodoesnt.work, http://www.dpodoesnt.work {
	redir https://www.dpodoesnt.work{uri} permanent
}

{$KIRIGAMI_CADDY_ADDR:https://www.dpodoesnt.work} {
	encode zstd gzip

	handle /api/* {
		reverse_proxy {$KIRIGAMI_API_UPSTREAM:127.0.0.1:8000}
	}

	reverse_proxy {$KIRIGAMI_WEB_UPSTREAM:127.0.0.1:3000}
}
