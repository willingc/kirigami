# Copy to `.env` in the kirigami project root (`.env` is gitignored).
#
# Discourse API credentials for https://discuss.python.org
# Create at: Preferences → Account → API → New API Key
#   https://discuss.python.org/my/preferences/api
#
# Used by kirigami.discourse (fetch, export) when load_env=True.
# Public PEP threads usually work without auth; API keys raise rate limits
# and may be required for private categories.

DISCOURSE_USERNAME=your_discourse_username
DISCOURSE_API_KEY=your_api_key_here
