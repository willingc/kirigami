# Copy to `.env` in the kirigami project root (`.env` is gitignored).
#
# Discourse API credentials for https://discuss.python.org
# Create at: Preferences -> Account -> API -> New API Key
#   https://discuss.python.org/my/preferences/api
#
# Leave values blank for public-only access.
#
# Use either:
# - DISCOURSE_USER_API_KEY for a key created from your Discourse user preferences.
# - DISCOURSE_API_KEY + DISCOURSE_USERNAME for an admin/global API key.

DISCOURSE_BASE_URL=https://discuss.python.org
DISCOURSE_USERNAME=
DISCOURSE_API_KEY=
DISCOURSE_USER_API_KEY=

# FastAPI Cloud deployment.
# Keep the real token in your local `.env` or GitHub Actions secrets; do not
# commit a filled-in value.
FASTAPI_CLOUD_TOKEN=
FASTAPI_CLOUD_APP_ID=

KIRIGAMI_DISCOURSE_CACHE_DIR=.cache/kirigami/discourse
KIRIGAMI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://localhost,https://127.0.0.1,https://www.dpodoesnt.work
KIRIGAMI_CORS_ORIGIN_REGEX=https://(www\.dpodoesnt\.work|localhost|127\.0\.0\.1|0\.0\.0\.0|10\.\d+\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+|192\.168\.\d+\.\d+)
KIRIGAMI_API_BASE_URL=http://backend:8000
NEXT_PUBLIC_API_BASE_URL=
KIRIGAMI_CADDY_ADDR=https://www.dpodoesnt.work
KIRIGAMI_API_UPSTREAM=backend:8000
KIRIGAMI_WEB_UPSTREAM=frontend:3000
KIRIGAMI_DOCKER_DATA_ROOT=/opt/kirigami-docker
KIRIGAMI_DOCKERD_LOG=/tmp/kirigami-dockerd.log
